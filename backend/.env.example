NODE_ENV=development
PORT=5000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=placement_tracker
DB_USER=postgres
DB_PASSWORD=postgres_secure_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
